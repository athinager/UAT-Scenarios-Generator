# Copy to `.env.local` for local API (never commit `.env.local`).
# Optional: override Vite asset base (default `/` on Vercel, `/UAT-Scenarios-Generator/` on GitHub Actions builds).
# VITE_BASE_URL=

# Required for `/api/uat`:
OPENAI_API_KEY=

# Optional OpenAI overrides (defaults: gpt-4o-mini, 4096 max output tokens — cheaper than gpt-4o)
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_OUTPUT_TOKENS=4096

# Optional: Figma REST API — enables pulling page/frame names into the scenario prompt.
# Create at: https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=
