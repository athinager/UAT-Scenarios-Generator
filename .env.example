# Copy to `.env.local` for local API (never commit `.env.local`).
# Optional: override Vite asset base (default `/` on Vercel, `/UAT-Scenarios-Generator/` on GitHub Actions builds).
# VITE_BASE_URL=

# --- AI provider (pick one) ---
# Auto-select: GEMINI_API_KEY → Gemini; else OPENAI_API_KEY → OpenAI
# Or force: AI_PROVIDER=gemini | openai

# Google Gemini (recommended) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_MAX_OUTPUT_TOKENS=4096

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_MAX_OUTPUT_TOKENS=4096

# Optional: Figma REST API — enables pulling page/frame names into the scenario prompt.
# Create at: https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=
